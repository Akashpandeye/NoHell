# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: match your app routes (set in Clerk Dashboard → Paths too)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: Settings → API → service_role (secret). Lets API routes bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Groq — server only (https://console.groq.com)
GROQ_API_KEY=

# Razorpay — server keys for orders + verify; public key for Checkout
# Default order: USD $9 (900 cents). Override if your Razorpay account uses INR only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Optional overrides (defaults: USD, 900 = $9.00)
# RAZORPAY_ORDER_CURRENCY=INR
# RAZORPAY_ORDER_AMOUNT_MINOR=74900
# Webhook signing (Dashboard → Webhooks → secret) — optional but recommended
RAZORPAY_WEBHOOK_SECRET=
