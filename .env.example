# --- Clerk (https://dashboard.clerk.com → API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: match your app routes (set in Clerk Dashboard → Paths too)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Vercel: add production URL (e.g. https://your-app.vercel.app) under
# Clerk → Domains / Authorized redirect URLs so sign-in works after deploy.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: service_role — never expose to the client; use in Vercel → Environment Variables → Production only or all envs as needed.
SUPABASE_SERVICE_ROLE_KEY=

# --- Groq (https://console.groq.com) — server only ---
GROQ_API_KEY=

# YouTube captions: unofficial fetch often fails from cloud IPs (e.g. Vercel).
# Optional: run tools/youtube_transcript_proxy.py elsewhere and point the app here (see tools/README.md).
# URL must include the path /transcript (e.g. https://your-proxy.example.com/transcript)
YOUTUBE_TRANSCRIPT_PROVIDER_URL=
YOUTUBE_TRANSCRIPT_PROVIDER_TOKEN=

# --- Razorpay (optional; omit if not using payments) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_ORDER_CURRENCY=INR
# RAZORPAY_ORDER_AMOUNT_MINOR=74900
RAZORPAY_WEBHOOK_SECRET=
